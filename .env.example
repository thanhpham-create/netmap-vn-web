# Backend API URL — đổi thành domain prod khi deploy
NEXT_PUBLIC_API_URL=http://localhost:8080

# Optional: site URL cho robots.txt + sitemap (default https://netmap.vn)
NEXT_PUBLIC_SITE_URL=

# Optional: MapTiler API key cho map tile chất lượng cao (free 100k req/mo).
# Đăng ký tại https://www.maptiler.com/cloud/. Nếu trống → dùng demotiles low-res.
NEXT_PUBLIC_MAPTILER_KEY=

# ============ ERROR MONITORING (Sentry) ============
# Public DSN — exposes to client bundle. OK to commit nhưng vẫn nên dùng env.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Server-side DSN (có thể trùng với public hoặc dùng project khác cho server logs)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Để upload source maps lên Sentry (deobfuscate stack traces) — chỉ set ở CI/Vercel:
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
